# GitHub (but keep workflows and dependabot)
# NOTE: use `.github/*` not `.github/` — a trailing-slash dir exclusion can't be undone by a
# child negation, which silently kept new workflow files (ci.yml, descent-ci.yml) untracked.
.github/*
!.github/workflows/
!.github/dependabot.yml

# Loader
loader/helldeck_loader.py

# Scripts
run_tests.sh
scripts/rewrite_*.py
scripts/fix_*.py
scripts/sync_*.py

# Ignore large local models and native build outputs
app/.cxx/
models/**/*.gguf
app/src/main/assets/models/*.gguf
*.gguf
